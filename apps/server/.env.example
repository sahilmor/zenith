PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/project-management
JWT_SECRET=replace-with-at-least-32-characters-secret
JWT_REFRESH_SECRET=replace-with-at-least-32-characters-refresh-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000
