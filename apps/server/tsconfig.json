{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "noEmit": false,
    "paths": {
      "@/*": ["./src/*"],
      "@pm/types": ["../../packages/types/src/index.ts"],
      "@pm/utils": ["../../packages/utils/src/index.ts"],
      "@pm/config/*": ["../../packages/config/src/*.ts"]
    },
    "rootDir": "../.."
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "vitest.config.ts"]
}
