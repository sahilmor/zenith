{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@pm/types": [
        "../../packages/types/src/index.ts"
      ],
      "@pm/utils": [
        "../../packages/utils/src/index.ts"
      ],
      "@pm/config/*": [
        "../../packages/config/src/*.ts"
      ],
      "@pm/ui": [
        "../../packages/ui/src/index.ts"
      ]
    },
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
